# ─────────────────────────────────────────────────────────────────────────────
# Asset Compliance AI — Environment Variables Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Local development mode
# ─────────────────────────────────────────────────────────────────────────────
# When LOCAL_OFFLINE=True the application uses local emulations of S3,
# DynamoDB, and Pinecone (no AWS or Pinecone credentials required). The
# Settings validator also auto-switches any agent or embedding provider
# whose API key is a placeholder string to the offline "local" provider
# so the application boots end-to-end without real credentials.
LOCAL_OFFLINE=False
SERVE_FRONTEND=True

# ─────────────────────────────────────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# S3 bucket that holds asset documents and audit images
S3_BUCKET_NAME=your-asset-docs-bucket

# ─────────────────────────────────────────────────────────────────────────────
# Pinecone
# ─────────────────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=asset-compliance
PINECONE_ENVIRONMENT=us-east-1-aws          # or your cloud/region

# ── LLM Providers ───────────────────────────────────────────────────────────
# You only need to provide API keys for the providers you actually use.
# Unused API keys can be left blank or deleted; the deployment script will
# automatically handle them.
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-proj-xxx
GOOGLE_API_KEY=AIzaSy...
XAI_API_KEY=your-xai-grok-api-key
OPENROUTER_API_KEY=sk-or-v1-...
# OpenCode Zen (https://opencode.ai/zen) — pay-as-you-go AI gateway. Optional.
# ZEN_API_KEY=your-opencode-zen-api-key
# OpenCode Go (https://opencode.ai/zen/go) — low-cost subscription. Optional.
# OPENCODE_GO_API_KEY=your-opencode-go-api-key

# ── Agent Configuration ───────────────────────────────────────────────────
# Configure the provider and model for each agent.
# Valid provider strings: openai, anthropic, google_genai, xai, grok,
# openrouter, zen, opencode_go, local.
IMAGE_AGENT_PROVIDER=xai
IMAGE_AGENT_MODEL=grok-vision-beta

RULE_AGENT_PROVIDER=xai
RULE_AGENT_MODEL=grok-beta

VERDICT_AGENT_PROVIDER=xai
VERDICT_AGENT_MODEL=grok-beta

CHAT_AGENT_PROVIDER=xai
CHAT_AGENT_MODEL=grok-beta

# Zen configuration example (uncomment to route agents through Zen):
# IMAGE_AGENT_PROVIDER=zen
# IMAGE_AGENT_MODEL=gpt-5.4
# RULE_AGENT_PROVIDER=zen
# RULE_AGENT_MODEL=qwen3.6-plus
# VERDICT_AGENT_PROVIDER=zen
# VERDICT_AGENT_MODEL=qwen3.7-plus
# CHAT_AGENT_PROVIDER=zen
# CHAT_AGENT_MODEL=qwen3.6-plus

# OpenCode Go configuration example (uncomment to route agents through Go):
# IMAGE_AGENT_PROVIDER=opencode_go
# IMAGE_AGENT_MODEL=qwen3.7-max
# RULE_AGENT_PROVIDER=opencode_go
# RULE_AGENT_MODEL=qwen3.6-plus
# VERDICT_AGENT_PROVIDER=opencode_go
# VERDICT_AGENT_MODEL=qwen3.7-plus
# CHAT_AGENT_PROVIDER=opencode_go
# CHAT_AGENT_MODEL=qwen3.6-plus

# ── LLM Config ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_CHAT_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────────────────────────────────────
# Note: The provider's API key must be set above in the LLM Providers section.
# Valid embedding provider values: openai, anthropic, google_genai, local.
# "local" uses the deterministic offline LocalEmbeddings provider
# (zero-vectors of EMBEDDING_DIMENSIONS length) — affects retrieval quality
# but allows end-to-end ingest without any network access.
EMBEDDING_PROVIDER=openai
# Embedding model name — change here to upgrade without code changes
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─────────────────────────────────────────────────────────────────────────────
# Web search fallback (DuckDuckGo - no API key required)
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# LangSmith (optional but recommended for agent tracing)
# ─────────────────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=asset-compliance-ai

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development                         # development | staging | production
LOG_LEVEL=INFO

# Top-k chunks to retrieve per Pinecone query (audit)
RETRIEVAL_TOP_K_AUDIT=20
# Top-k chunks to retrieve per Pinecone query (chat)
RETRIEVAL_TOP_K_CHAT=12

# Document chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─────────────────────────────────────────────────────────────────────────────
# DynamoDB
# ─────────────────────────────────────────────────────────────────────────────
# Table name is set automatically by CloudFormation (DYNAMODB_AUDIT_TABLE = !Ref AuditRunsTable).
# For local development, create the table manually and set the name here.
DYNAMODB_AUDIT_TABLE=audit-compliance-runs-development

# ─────────────────────────────────────────────────────────────────────────────
# Security — CORS
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Set to your Django app origin in production to prevent the
# wildcard CORS + credentials vulnerability (SEC-1 from audit).
# Format: JSON array of allowed origins.
CORS_ALLOWED_ORIGINS=["https://app.yourdomain.com"]

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
# Format: "<count>/<period>" (period: second, minute, hour, day)
RATE_LIMIT_AUDIT=10/minute
RATE_LIMIT_INGEST=30/minute
RATE_LIMIT_CHAT=60/minute

# API authentication — this key must match the API_SECRET_KEY configured
# in your Django asset management system. All requests from Django must
# include the header: X-API-Key: <this value>
API_SECRET_KEY=your-shared-secret-key-min-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# SAM / Lambda (used by samconfig.toml and Makefile)
# ─────────────────────────────────────────────────────────────────────────────
SAM_STACK_NAME=asset-compliance-ai
SAM_S3_BUCKET=your-sam-deployment-bucket
SAM_REGION=us-east-1
